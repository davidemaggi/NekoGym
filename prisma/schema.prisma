generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  ADMIN
  TRAINER
  TRAINEE
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
}

enum SubscriptionPlanType {
  NONE
  WEEKLY
  MONTHLY
  FIXED
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum LessonStatus {
  SCHEDULED
  CANCELLED
}

enum NotificationChannel {
  EMAIL
  TELEGRAM
  WEBPUSH
}

enum NotificationStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

enum AuthTokenType {
  EMAIL_VERIFICATION
  EMAIL_CHANGE
  PASSWORD_RESET
  LOGIN_OTP
  LOGIN_MAGIC_LINK
  LOGIN_2FA_CHALLENGE
}

model User {
  id                    String               @id @default(cuid())
  name                  String
  email                 String               @unique
  emailVerifiedAt       DateTime?
  pendingEmail          String?              @unique
  passwordHash          String
  role                  UserRole             @default(TRAINEE)
  telegramChatId        String?              @unique
  telegramUsername      String?
  telegramLinkedAt      DateTime?
  notifyByEmail         Boolean              @default(true)
  notifyByTelegram      Boolean              @default(true)
  notifyByWebPush       Boolean              @default(true)
  totpEnabled           Boolean              @default(false)
  totpSecret            String?
  membershipStatus      MembershipStatus     @default(INACTIVE)
  trialEndsAt           DateTime?
  subscriptionType      SubscriptionPlanType @default(NONE)
  subscriptionLessons   Int?
  subscriptionRemaining Int?
  subscriptionResetAt   DateTime?
  subscriptionEndsAt    DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  sessions              Session[]
  courses               Course[]             @relation("CourseTrainer")
  lessons               Lesson[]             @relation("LessonTrainer")
  lessonBookings        LessonBooking[]
  lessonWaitlistEntries LessonWaitlistEntry[]
  telegramLinkTokens    TelegramLinkToken[]
  notificationOutbox    NotificationOutbox[]
  authTokens            AuthToken[]
  webPushSubscriptions  WebPushSubscription[]
}

model NotificationOutbox {
  id          String              @id @default(cuid())
  userId      String
  recipientEmail String?
  allowUnverifiedEmail Boolean @default(false)
  channel     NotificationChannel
  subject     String?
  body        String
  status      NotificationStatus  @default(PENDING)
  attempts    Int                 @default(0)
  availableAt DateTime            @default(now())
  lastError   String?
  sentAt      DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, availableAt, createdAt])
  @@index([userId, createdAt])
}

model AuthToken {
  id          String       @id @default(cuid())
  type        AuthTokenType
  tokenHash   String       @unique
  targetEmail String?
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime     @default(now())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
}

model WebPushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TelegramLinkToken {
  id         String    @id @default(cuid())
  token      String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Course {
  id                      String               @id @default(cuid())
  name                    String
  description             String?
  icon                    String?
  durationMinutes         Int
  maxAttendees            Int
  trainerName             String?
  trainerId               String?
  lessonTypeId            String?
  bookingAdvanceMonths    Int                  @default(1)
  cancellationWindowHours Int                  @default(24)
  deletedAt               DateTime?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  scheduleSlots           CourseScheduleSlot[]
  trainer                 User?                @relation("CourseTrainer", fields: [trainerId], references: [id], onDelete: SetNull)
  lessonType              LessonType?          @relation(fields: [lessonTypeId], references: [id], onDelete: SetNull)
  lessons                 Lesson[]

  @@index([name])
  @@index([trainerId])
  @@index([lessonTypeId])
  @@index([deletedAt])
}

model LessonType {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  iconSvg     String
  colorHex    String   @default("#2563EB")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  courses     Course[]
  lessons     Lesson[]
}

model Lesson {
  id                      String          @id @default(cuid())
  title                   String?
  description             String?
  startsAt                DateTime
  endsAt                  DateTime
  status                  LessonStatus    @default(SCHEDULED)
  deletedAt               DateTime?
  maxAttendees            Int
  cancellationWindowHours Int             @default(24)
  sourceWeekday           Weekday?
  sourceStartTime         String?
  isGenerated             Boolean         @default(true)
  isCustomized            Boolean         @default(false)
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  courseId                String?
  lessonTypeId            String?
  trainerId               String?
  course                  Course?         @relation(fields: [courseId], references: [id], onDelete: SetNull)
  lessonType              LessonType?     @relation(fields: [lessonTypeId], references: [id], onDelete: SetNull)
  trainer                 User?           @relation("LessonTrainer", fields: [trainerId], references: [id], onDelete: SetNull)
  bookings                LessonBooking[]
  waitlistEntries         LessonWaitlistEntry[]

  @@index([courseId])
  @@index([courseId, startsAt])
  @@index([lessonTypeId])
  @@index([trainerId])
  @@index([startsAt])
  @@index([status])
  @@index([deletedAt])
}

model LessonBooking {
  id        String   @id @default(cuid())
  lessonId  String
  traineeId String
  createdAt DateTime @default(now())
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  trainee   User     @relation(fields: [traineeId], references: [id], onDelete: Cascade)

  @@unique([lessonId, traineeId])
  @@index([traineeId])
}

model LessonWaitlistEntry {
  id        String   @id @default(cuid())
  lessonId  String
  traineeId String
  createdAt DateTime @default(now())
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  trainee   User     @relation(fields: [traineeId], references: [id], onDelete: Cascade)

  @@unique([lessonId, traineeId])
  @@index([lessonId, createdAt])
  @@index([traineeId])
}

model CourseScheduleSlot {
  id        String  @id @default(cuid())
  courseId  String
  weekday   Weekday
  startTime String
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, weekday, startTime])
  @@index([courseId, weekday])
}

model SiteSettings {
  id                 Int      @id @default(1)
  siteName           String   @default("NekoGym")
  siteLogoSvg        String   @default("/logo-nekogym.svg")
  weeklyResetWeekday Weekday  @default(MONDAY)
  openWeekdaysCsv    String   @default("MONDAY,TUESDAY,WEDNESDAY,THURSDAY,FRIDAY,SATURDAY")
  closedDatesCsv     String   @default("")
  smtpHost           String?
  smtpPort           Int?
  smtpAuthEnabled    Boolean?
  smtpUser           String?
  smtpPassword       String?
  smtpFromEmail      String?
  contactAddress     String?
  contactEmail       String?
  contactPhone       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
